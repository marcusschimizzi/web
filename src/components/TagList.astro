---
interface Props {
    tags: string[];
}

const { tags } = Astro.props;
---

<div class="flex flex-wrap gap-2">
    {tags.map((tag) => (
        <a
            href={`/tags/${tag}`}
            class="bg-gray-800 text-primary-400 px-3 py-1 rounded-full text-sm hover:bg-gray-700 transition-colors"
        >
            {tag}
        </a>
    ))}
</div>
