<div class="epithets-container">
    <div class="epithets-row epithets-row-1">
        <div class="epithets-wrapper">
            <span class="epithet">Software developer,</span>
            <span class="epithet">Lifelong learner,</span>
            <span class="epithet">Data visualization buff,</span>
            <span class="epithet">Tinkerer,</span>
        </div>
    </div>
    <div class="epithets-row epithets-row-2">
        <div class="epithets-wrapper">
            <span class="epithet">travel enthusiast,</span>
            <span class="epithet">amateur chef,</span>
            <span class="epithet">big sports guy,</span>
        </div>
    </div>
    <div class="epithets-row epithets-row-3">
        <div class="epithets-wrapper">
            <span class="epithet">and current Chicagoan.</span>
            <span class="epithet">and Notre Dame alum.</span>
            <span class="epithet">and consumer of too much coffee.</span>
            <span class="epithet">and multitime pub trivia champion.</span>
        </div>
    </div>
</div>

<style>
    :root {
        --epithet-height: 3rem;
    }

    @media (min-width: 768px) {
        :root {
            --epithet-height: 4.5rem;
        }
    }

    .epithets-container {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        margin: 1.5rem 0;
    }

    .epithets-row {
        overflow: hidden;
        height: var(--epithet-height);
    }

    .epithets-wrapper {
        display: flex;
        flex-direction: column;
    }

    .epithet {
        display: block;
        line-height: var(--epithet-height);
        flex-shrink: 0;
        font-size: 1.5rem;
        font-weight: 700;
        background: linear-gradient(160deg, #3a9cf7 0%, #c084fc 50%, #818cf8 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    @media (min-width: 768px) {
        .epithet {
            font-size: 1.875rem;
        }
    }

    @media (min-width: 1024px) {
        .epithet {
            font-size: 2.25rem;
        }
    }

    /* Row 1: Professional (4 items, 48s cycle) */
    .epithets-row-1 .epithets-wrapper {
        animation: rotateRow1 48s cubic-bezier(0.45, 0.05, 0.55, 0.95) infinite;
    }

    @keyframes rotateRow1 {
        0%, 21.6% {
            transform: translateY(0);
        }
        25%, 46.6% {
            transform: translateY(calc(-1 * var(--epithet-height)));
        }
        50%, 71.6% {
            transform: translateY(calc(-2 * var(--epithet-height)));
        }
        75%, 96.6% {
            transform: translateY(calc(-3 * var(--epithet-height)));
        }
        100% {
            transform: translateY(0);
        }
    }

    /* Row 2: Interests (3 items, 39s cycle, 5s delay offset) */
    .epithets-row-2 .epithets-wrapper {
        animation: rotateRow2 39s cubic-bezier(0.45, 0.05, 0.55, 0.95) infinite;
        animation-delay: 5s;
    }

    @keyframes rotateRow2 {
        0%, 28.8% {
            transform: translateY(0);
        }
        33.3%, 62.1% {
            transform: translateY(calc(-1 * var(--epithet-height)));
        }
        66.6%, 95.4% {
            transform: translateY(calc(-2 * var(--epithet-height)));
        }
        100% {
            transform: translateY(0);
        }
    }

    /* Row 3: Descriptive (4 items, 56s cycle, 11s delay offset) */
    .epithets-row-3 .epithets-wrapper {
        animation: rotateRow3 56s cubic-bezier(0.45, 0.05, 0.55, 0.95) infinite;
        animation-delay: 11s;
    }

    @keyframes rotateRow3 {
        0%, 21.6% {
            transform: translateY(0);
        }
        25%, 46.6% {
            transform: translateY(calc(-1 * var(--epithet-height)));
        }
        50%, 71.6% {
            transform: translateY(calc(-2 * var(--epithet-height)));
        }
        75%, 96.6% {
            transform: translateY(calc(-3 * var(--epithet-height)));
        }
        100% {
            transform: translateY(0);
        }
    }
</style>
