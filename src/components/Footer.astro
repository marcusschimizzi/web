---
import { features } from '@/config';

const currentYear = new Date().getFullYear();
---

<footer class="border-t border-gray-800">
  <div class="max-w-6xl mx-auto px-4 py-10 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row md:items-start gap-8 md:gap-20 lg:gap-32">
      <!-- Brand -->
      <div class="md:max-w-xs shrink-0">
        <a href="/">
          <img src="/images/logo-gradient.svg" alt="Marcus Schimizzi" class="h-12 w-12" />
        </a>
        <h3 class="text-lg font-semibold mt-2 text-white">Marcus J. Schimizzi</h3>
        <p class="text-gray-300">I'm a passionate software engineer specializing in web development and data visualization.</p>
      </div>

      <!-- Link columns -->
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-8 flex-1">
        <!-- Pages -->
        <div>
          <h4 class="text-lg font-semibold text-white mb-4">Pages</h4>
          <ul class="space-y-2">
            <li>
              <a href="/about" class="text-gray-300 hover:text-primary-400 transition-colors">About</a>
            </li>
            <li>
              <a href="/projects" class="text-gray-300 hover:text-primary-400 transition-colors">Projects</a>
            </li>
            <li>
              <a href="/experience" class="text-gray-300 hover:text-primary-400 transition-colors">Experience</a>
            </li>
            {features.blog && (
            <li>
              <a href="/blog" class="text-gray-300 hover:text-primary-400 transition-colors">Blog</a>
            </li>
            )}
            <li>
              <a href="/contact" class="text-gray-300 hover:text-primary-400 transition-colors">Contact</a>
            </li>
          </ul>
        </div>

        <!-- More -->
        <div>
          <h4 class="text-lg font-semibold text-white mb-4">More</h4>
          <ul class="space-y-2">
            <li>
              <a href="/now" class="text-gray-300 hover:text-primary-400 transition-colors">Now</a>
            </li>
            <li>
              <a href="/uses" class="text-gray-300 hover:text-primary-400 transition-colors">Uses</a>
            </li>
            <li>
              <a href="/docs/resume.pdf" class="text-gray-300 hover:text-primary-400 transition-colors">Resume</a>
            </li>
            <li>
              <a href="/colophon" class="text-gray-300 hover:text-primary-400 transition-colors">Colophon</a>
            </li>
          </ul>
        </div>

        <!-- Connect -->
        <div>
          <h4 class="text-lg font-semibold text-white mb-4">Connect</h4>
          <ul class="space-y-2">
            <li>
              <a href="https://github.com/marcusschimizzi" target="_blank" rel="noopener noreferrer" class="text-gray-300 hover:text-primary-400 transition-colors">GitHub</a>
            </li>
            <li>
              <a href="https://linkedin.com/in/marcusschimizzi" target="_blank" rel="noopener noreferrer" class="text-gray-300 hover:text-primary-400 transition-colors">LinkedIn</a>
            </li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-8 pt-8 border-t border-gray-800 text-center text-gray-400">
      <p>Made by me with ❤️ and lots of ☕</p>
      <p>&copy; {currentYear} Marcus Schimizzi. All rights reserved.</p>
    </div>
  </div>
</footer>
