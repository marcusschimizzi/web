---
interface Props {
    title: string;
    description: string;
    image?: string;
    url?: string;
    type?: 'website' | 'article' | 'project';
    publishedTime?: string;
    tags?: string[];
    technologies?: string[];
    projectUrl?: string;
}

const { title, description, image, url, type = 'website', publishedTime, tags, technologies, projectUrl } = Astro.props;

const siteURL = Astro.site ? new URL(Astro.site).origin : 'https://schimizzi.io';
const canonicalURL = url ? `${siteURL}${url}` : `${siteURL}${Astro.url.pathname}`;
const pathname = Astro.url.pathname;
const ogSlug = pathname === '/' ? 'index' : pathname.replace(/^\/|\/$/g, '');
const ogImage = image || `/og/${ogSlug}.png`;

// Schema map for flexible JSON-LD generation
const schemaMap = {
    website: {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Marcus Schimizzi",
        "url": "https://schimizzi.io",
        "sameAs": [
            "https://github.com/marcusschimizzi",
            "https://linkedin.com/in/marcusschimizzi"
        ],
        "jobTitle": "Software Engineer"
    },
    article: {
        "@context": "https://schema.org",
        "@type": "BlogPosting",
        "headline": title,
        "description": description,
        "image": `${siteURL}${ogImage}`,
        "url": canonicalURL,
        "datePublished": publishedTime || '',
        "author": {
            "@type": "Person",
            "name": "Marcus Schimizzi",
            "url": "https://schimizzi.io"
        }
    },
    project: {
        "@context": "https://schema.org",
        "@type": "SoftwareSourceCode",
        "name": title,
        "description": description,
        "programmingLanguage": technologies || [],
        "url": projectUrl || canonicalURL,
        "author": {
            "@type": "Person",
            "name": "Marcus Schimizzi"
        }
    }
};

// For homepage, render both Person and WebSite schemas
const getJsonLd = () => {
    if (type === 'website') {
        return {
            "@context": "https://schema.org",
            "@graph": [
                schemaMap.website,
                {
                    "@type": "WebSite",
                    "name": "Marcus Schimizzi",
                    "url": "https://schimizzi.io",
                    "description": "Portfolio of Marcus Schimizzi — software engineer, lifelong learner, and tinkerer."
                }
            ]
        };
    }
    return schemaMap[type as keyof typeof schemaMap] || schemaMap.website;
};

const jsonLd = getJsonLd();
---

<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />

<!-- OpenGraph -->
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={`${siteURL}${ogImage}`} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:url" content={canonicalURL} />
<meta property="og:type" content={type} />
<meta property="og:site_name" content="Marcus Schimizzi" />
<meta property="og:locale" content="en_US" />
{tags && tags.map((tag) => <meta property="article:tag" content={tag} />)}

<!-- Twitter Cards -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={`${siteURL}${ogImage}`} />

<!-- JSON-LD -->
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
