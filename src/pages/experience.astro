---
import PageLayout from '@layouts/PageLayout.astro';
import ExperienceEntry from '@components/ExperienceEntry.astro';
---

<PageLayout
    title="Experience | Marcus Schimizzi"
    description="Software engineer with experience at Qualia, Qualtrics, Ford Motor Company, and freelance web development."
>
    <div class="max-w-4xl mx-auto">
        <!-- Experience Section -->
        <section class="mb-16">
            <h2 class="text-3xl font-bold text-white mb-8">Experience</h2>

            <ExperienceEntry
                institution="Qualia"
                role="Software Engineer"
                startDate="December 2024"
                endDate="Now"
                description="Building systems to automate real estate title searches and exams on the Search & Exam team. Full-stack work spanning web scraping, multi-agent orchestration, and prompt engineering."
                image="/images/qualia.png"
            />

            <ExperienceEntry
                institution="Qualtrics"
                role="Software Development Engineer"
                startDate="August 2019"
                endDate="March 2024"
                description="Built features for the XM Platform on the Data Visualization team. Full-stack with emphasis on the front end — React, TypeScript, D3, and Golang."
                image="/images/xm.png"
            />

            <ExperienceEntry
                institution="Ford Motor Company"
                role="Software Engineering Intern"
                startDate="May 2018"
                endDate="August 2018"
                description="Built a gamified training and onboarding app for call center employees. Full-stack — React and JavaScript on the front end, Java and Spring Boot on the back end."
                image="/images/ford.svg"
            />

            <ExperienceEntry
                institution="Self Employed"
                role="Freelance Web Developer"
                startDate="May 2014"
                endDate="August 2019"
                description="Designed and built websites and web applications for small business clients. Shipped projects across HTML, CSS, JavaScript, React, Node.js, PHP, and MongoDB while learning the craft of client management and project delivery."
                image="/images/logo.svg"
            />
        </section>

        <!-- Education Section -->
        <section>
            <h2 class="text-3xl font-bold text-white mb-8">Education</h2>

            <ExperienceEntry
                institution="University of Notre Dame"
                role="B.S.E. in Computer Science"
                startDate="August 2015"
                endDate="May 2019"
                description="I graduated from the University of Notre Dame with a B.S.E. in Computer Science. I took a variety of courses in computer science, mathematics, and engineering."
                image="/images/notredame.jpg"
            />

            <ExperienceEntry
                institution="London, UK"
                role="London Study Abroad"
                startDate="January 2018"
                endDate="May 2018"
                description="During my time at the University of Notre Dame, I got the chance to spend a semester abroad in London. It was a great experience and London remains one of my favorite cities."
            />
        </section>
    </div>
</PageLayout>
